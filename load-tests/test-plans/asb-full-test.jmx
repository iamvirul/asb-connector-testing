      <hashTree>
        <!-- 13. Queue Exists -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="13. GET /admin/queueExists/{queueName}" enabled="true">
          <stringProp name="HTTPSampler.path">/admin/queueExists/${QUEUE_NAME}</stringProp>
