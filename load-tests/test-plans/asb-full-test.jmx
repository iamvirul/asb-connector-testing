        <!-- 8. Update Topic -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="08. PUT /admin/updateTopic" enabled="true">
          <stringProp name="HTTPSampler.path">/admin/updateTopic</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
