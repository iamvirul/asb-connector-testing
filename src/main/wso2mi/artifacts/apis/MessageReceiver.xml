<?xml version="1.0" encoding="UTF-8"?>
<api context="/messagereceiver" name="MessageReceiver" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="GET" uri-template="/receive">
        <inSequence>
            <asb.MessageReceiver_receive configKey="asb_messagereceiver_connection">
                <responseVariable>asb_MessageReceiver_receive_1</responseVariable>
                <overwriteBody>true</overwriteBody>
                <serverWaitTime>60</serverWaitTime>
                <deadLettered>false</deadLettered>
            </asb.MessageReceiver_receive>
            <respond/>
        </inSequence>
        <faultSequence>
            <sequence key="CommonFaultSequence"/>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/receivePayload">
        <inSequence>
            <asb.MessageReceiver_receivePayload configKey="asb_messagereceiver_connection">
                <responseVariable>asb_MessageReceiver_receivePayload_1</responseVariable>
                <overwriteBody>true</overwriteBody>
                <serverWaitTime>60</serverWaitTime>
                <deadLettered>false</deadLettered>
            </asb.MessageReceiver_receivePayload>
            <respond/>
        </inSequence>
        <faultSequence>
            <sequence key="CommonFaultSequence"/>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/receiveBatch/{count}">
        <inSequence>
            <asb.MessageReceiver_receiveBatch configKey="asb_messagereceiver_connection">
                <responseVariable>asb_MessageReceiver_receiveBatch_1</responseVariable>
                <overwriteBody>true</overwriteBody>
                <maxMessageCount>{${params.pathParams.count}}</maxMessageCount>
                <serverWaitTime></serverWaitTime>
                <deadLettered>false</deadLettered>
            </asb.MessageReceiver_receiveBatch>
            <respond/>
        </inSequence>
        <faultSequence>
            <sequence key="CommonFaultSequence"/>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/close">
        <inSequence>
            <asb.MessageReceiver_close configKey="asb_messagereceiver_connection">
                <responseVariable>asb_MessageReceiver_close_1</responseVariable>
                <overwriteBody>true</overwriteBody>
            </asb.MessageReceiver_close>
            <respond/>
        </inSequence>
        <faultSequence>
            <sequence key="CommonFaultSequence"/>
        </faultSequence>
    </resource>
</api>